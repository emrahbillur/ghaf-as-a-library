diff --git a/drivers/net/dsa/microchip/Kconfig b/drivers/net/dsa/microchip/Kconfig
index 394ca8678..93fee5d1f 100755
--- a/drivers/net/dsa/microchip/Kconfig
+++ b/drivers/net/dsa/microchip/Kconfig
@@ -8,6 +8,20 @@ menuconfig NET_DSA_MICROCHIP_KSZ_COMMON
 	  This driver adds support for Microchip KSZ9477 series switch and
 	  KSZ8795/KSZ88x3 switch chips.
 
+config NET_DSA_MICROCHIP_DISABLE_DSA
+	bool "Disable DSA functionality, static port member config only"
+	depends on NET_DSA_MICROCHIP_KSZ_COMMON
+	default n
+	help
+	 No DSA for 9477, just init
+
+config NET_DSA_MICROCHIP_ENABLE_MODULE_PARAM
+	bool "Enable port membership values by module parameters"
+	depends on NET_DSA_MICROCHIP_KSZ_COMMON
+	default n
+	help
+	 Overwrite device tree parameters for KSZ9477 if given
+
 config NET_DSA_MICROCHIP_KSZ9477_I2C
 	tristate "KSZ series I2C connected switch driver"
 	depends on NET_DSA_MICROCHIP_KSZ_COMMON && I2C
diff --git a/drivers/net/dsa/microchip/ksz9477.c b/drivers/net/dsa/microchip/ksz9477.c
index a11f2c1aa..1b69bd0b4 100755
--- a/drivers/net/dsa/microchip/ksz9477.c
+++ b/drivers/net/dsa/microchip/ksz9477.c
@@ -1200,7 +1200,14 @@ int ksz9477_setup(struct dsa_switch *ds)
 	/* Required for port partitioning. */
 	ksz9477_cfg32(dev, REG_SW_QM_CTRL__4, UNICAST_VLAN_BOUNDARY,
 		      true);
-
+#ifdef CONFIG_NET_DSA_MICROCHIP_DISABLE_DSA
+	{
