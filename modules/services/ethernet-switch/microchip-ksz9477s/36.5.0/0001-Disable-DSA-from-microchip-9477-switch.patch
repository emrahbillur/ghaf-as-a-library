+		usleep_range(200000, 210000); // 150ms was tested to be enoguh to get I2C bootstrap low
 		gpiod_set_value_cansleep(dev->reset_gpio, 0);
 		msleep(100);
 	}
@@ -3589,6 +3589,11 @@ int ksz_switch_register(struct ksz_device *dev)
 	if (ret)
 		return ret;
 
+#ifdef CONFIG_NET_DSA_MICROCHIP_DISABLE_DSA
+	/* call setup func before setting up port members, no full dsa init/setup */
+	dev->ds->ops->setup(dev->ds);
+#endif
+
 	dev->ports = devm_kzalloc(dev->dev,
 				  dev->info->port_cnt * sizeof(struct ksz_port),
 				  GFP_KERNEL);
@@ -3636,7 +3641,22 @@ int ksz_switch_register(struct ksz_device *dev)
 				}
 				of_get_phy_mode(port,
 						&dev->ports[port_num].interface);
-
+#ifdef CONFIG_NET_DSA_MICROCHIP_DISABLE_DSA
+								{
+										u32 member = -1;
+#ifdef CONFIG_NET_DSA_MICROCHIP_ENABLE_MODULE_PARAM
+										if (dev->num_elements > port_num) {
+												member = dev->port_member[port_num];
+												dev->dev_ops->cfg_port_member(dev, port_num, member & dev->port_mask);
+										}
+#endif
+										if (member == (u32)-1) {  // If module param was NOT set, fallback to DT
+												if (!of_property_read_u32(port, "member", &member)) {
+														dev->dev_ops->cfg_port_member(dev, port_num, member & dev->port_mask);
+												}
+										}
+								}
+#endif
 				ksz_parse_rgmii_delay(dev, port_num, port);
 			}
 			of_node_put(ports);
@@ -3650,7 +3670,7 @@ int ksz_switch_register(struct ksz_device *dev)
 			return -EINVAL;
 		}
 	}
-
+#ifndef CONFIG_NET_DSA_MICROCHIP_DISABLE_DSA
 	ret = dsa_register_switch(dev->ds);
 	if (ret) {
 		dev->dev_ops->exit(dev);
@@ -3662,6 +3682,7 @@ int ksz_switch_register(struct ksz_device *dev)
 
 	/* Start the MIB timer. */
 	schedule_delayed_work(&dev->mib_read, 0);
+#endif
 
 	return ret;
 }
@@ -3676,7 +3697,9 @@ void ksz_switch_remove(struct ksz_device *dev)
 	}
 
 	dev->dev_ops->exit(dev);
+#ifndef CONFIG_NET_DSA_MICROCHIP_DISABLE_DSA	
 	dsa_unregister_switch(dev->ds);
+#endif
 
 	if (dev->reset_gpio)
 		gpiod_set_value_cansleep(dev->reset_gpio, 1);
